{
  "name": "alphasignal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --sort build",
    "dev": "pnpm --parallel --filter @alphasignal/api --filter @alphasignal/web dev",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter @alphasignal/web test:e2e",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @alphasignal/db prisma:generate",
    "db:migrate": "pnpm --filter @alphasignal/db prisma:migrate",
    "db:seed": "pnpm --filter @alphasignal/db prisma:seed",
    "clean": "pnpm -r --if-present clean"
  },
  "devDependencies": {
    "@eslint/js": "9.13.0",
    "@types/node": "20.17.6",
    "eslint": "9.13.0",
    "prettier": "3.3.3",
    "typescript": "5.6.3",
    "typescript-eslint": "8.11.0"
  }
}
