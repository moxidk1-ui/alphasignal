{
  "name": "@alphasignal/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx watch --conditions=development src/server.ts",
    "lint": "eslint .",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@alphasignal/db": "workspace:*",
    "@alphasignal/algo-engine": "workspace:*",
    "@alphasignal/indicators": "workspace:*",
    "@alphasignal/queue": "workspace:*",
    "@alphasignal/shared": "workspace:*",
    "@fastify/cookie": "9.4.0",
    "@fastify/cors": "9.0.1",
    "@fastify/helmet": "11.1.1",
    "@fastify/sensible": "5.6.0",
    "@fastify/swagger": "8.15.0",
    "@fastify/swagger-ui": "2.1.0",
    "bcryptjs": "2.4.3",
    "bullmq": "5.58.4",
    "dotenv": "16.4.5",
    "fastify": "4.28.1",
    "ioredis": "5.4.1",
    "jose": "5.9.6",
    "opossum": "8.4.0",
    "pino": "9.4.0",
    "resend": "6.0.3",
    "stripe": "17.3.1",
    "telegraf": "4.16.3",
    "ws": "8.18.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@alphasignal/config": "workspace:*",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.17.6",
    "@types/opossum": "8.1.9",
    "@types/ws": "8.5.13",
    "pino-pretty": "11.3.0",
    "tsx": "4.19.2",
    "vitest": "2.1.4"
  }
