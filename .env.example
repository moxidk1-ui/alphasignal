# App
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# Auth (RS256)
# Generate a local keypair with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096 -out jwt_private.pem
#   openssl rsa -pubout -in jwt_private.pem -out jwt_public.pem
# Store PEM values with escaped newlines when exporting in a single-line environment.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-private-key\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-with-public-key\n-----END PUBLIC KEY-----"
JWT_REFRESH_SECRET=replace-with-64-random-characters

# Database
# Docker host port; set both values to 5433 if port 5432 is already used locally.
POSTGRES_PORT=5432
DATABASE_URL=postgresql://alphasignal:alphasignal_dev_password@localhost:5432/alphasignal?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-with-key

# Market Data
ALPACA_API_KEY=replace-with-key
ALPACA_API_SECRET=replace-with-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex
ALPACA_RATE_LIMIT_PER_MINUTE=200
BINANCE_API_KEY=replace-with-key
BINANCE_API_SECRET=replace-with-secret
BINANCE_BASE_URL=https://api.binance.com
BINANCE_STREAM_URL=wss://stream.binance.com:9443/ws
BINANCE_WEIGHT_LIMIT_PER_MINUTE=1200
ALPHA_VANTAGE_API_KEY=replace-with-key
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
ALPHA_VANTAGE_CALLS_PER_MINUTE=5
POLYGON_API_KEY=replace-with-key
POLYGON_BASE_URL=https://api.polygon.io
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com

# Billing
# Create recurring monthly products in Stripe for Pro ($29) and Provider ($79).
# For local webhook verification run:
#   stripe listen --forward-to localhost:4000/webhooks/stripe
STRIPE_SECRET_KEY=sk_test_replace-with-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-secret
STRIPE_PRO_PRICE_ID=price_replace_with_pro_price
STRIPE_PROVIDER_PRICE_ID=price_replace_with_provider_price

# Email
RESEND_API_KEY=re_replace-with-key
EMAIL_FROM=AlphaSignal <signals@alphasignal.app>

# Telegram
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-secret-token

# Next.js (public)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# NextAuth
NEXTAUTH_SECRET=replace-with-64-random-characters
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=replace-with-client-id
GOOGLE_CLIENT_SECRET=replace-with-client-secret

# Seed data (development and test only)
SEED_USER_PASSWORD=AlphaSignalSeed!2026
