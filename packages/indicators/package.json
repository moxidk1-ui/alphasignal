{
  "name": "@alphasignal/indicators",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@alphasignal/shared": "workspace:*"
  },
  "devDependencies": {
    "@alphasignal/config": "workspace:*",
    "@vitest/coverage-v8": "2.1.4",
    "vitest": "2.1.4"
  }
}
